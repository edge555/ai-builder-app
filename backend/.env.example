# AI Provider Configuration
# Options: modal | openrouter (default: openrouter)
AI_PROVIDER=openrouter

# OpenRouter API Configuration (required when AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
MAX_OUTPUT_TOKENS=16384

# Modal API Configuration (required when AI_PROVIDER=modal)
# URL format: https://<username>--<app-name>-<function-name>.modal.run
MODAL_API_URL=https://ai-builder--ai-code-builder-generate-api.modal.run
# MODAL_API_KEY=your_modal_api_key_here  # optional auth
# MODAL_TIMEOUT=120000                   # optional, default 120000ms (2 min)

# CORS Configuration
# Comma-separated list of allowed origins for CORS
# Examples:
#   Single origin: http://localhost:8080
#   Multiple origins: http://localhost:8080,http://localhost:5173,https://your-domain.com
ALLOWED_ORIGINS=http://localhost:8080

# Logging Configuration
LOG_LEVEL=info

