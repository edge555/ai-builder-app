# AI Provider Configuration
# Options: modal | openrouter (default: openrouter)
# Note: this can also be overridden at runtime via the /settings/agents page.
AI_PROVIDER=openrouter

# OpenRouter API Configuration (required when AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Modal API Configuration (required when AI_PROVIDER=modal)
# URL format: https://<username>--<app-name>-<function-name>.modal.run
MODAL_API_URL=https://ai-builder--ai-code-builder-generate-api.modal.run
MODAL_STREAM_API_URL=https://ai-builder--ai-code-builder-generate-stream-api.modal.run
# MODAL_API_KEY=your_modal_api_key_here   # optional: set if your Modal endpoint requires auth
MODAL_TIMEOUT=900000                       # optional: request timeout in ms (default 900000 = 15 min)

# Output token limits (applies to OpenRouter; Modal uses its own server-side limits)
MAX_OUTPUT_TOKENS=16384

# CORS Configuration
# Comma-separated list of allowed origins
# Examples:
#   Single origin:    http://localhost:8080
#   Multiple origins: http://localhost:8080,http://localhost:5173,https://your-domain.com
ALLOWED_ORIGINS=http://localhost:8080

# Logging
# Options: debug, info (default), warn, error
LOG_LEVEL=info

# Log output format
# Options: text (default), json
LOG_FORMAT=text

# Log categories - comma-separated list to enable specific categories
# Options: ai, api, core, diff, analysis, streaming (default: all)
# Example: LOG_CATEGORIES=ai,api
LOG_CATEGORIES=ai,api,core,diff,analysis,streaming

# Write logs to file (backend/logs/generation-YYYY-MM-DD.log)
# Set to true to enable; logs/ directory is gitignored
# LOG_FILE=true

# Supabase Auth (optional — if unset, JWT verification is skipped)
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here
