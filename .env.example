# AI App Builder - Root Environment Configuration Example

# This file documents all environment variables used across the monorepo.
# Copy this to .env (not used by any build tool directly yet, but helpful for documentation)
# or use individual .env files in backend/ and frontend/ directories.

# --- Backend Configuration ---
# AI Provider Configuration
# Options: gemini | modal (default: gemini)
AI_PROVIDER=gemini

# Gemini API Configuration (required when AI_PROVIDER=gemini)
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EASY_MODEL=gemini-2.5-flash-lite
GEMINI_HARD_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT=60000
GEMINI_MAX_RETRIES=3
MAX_OUTPUT_TOKENS=16384

# Modal API Configuration (required when AI_PROVIDER=modal)
# URL format: https://<username>--<app-name>-<function-name>.modal.run
MODAL_API_URL=https://ai-builder--ai-code-builder-generate-api.modal.run
# MODAL_API_KEY=your_modal_api_key_here  # optional auth
# MODAL_TIMEOUT=120000                   # optional, default 120000ms (2 min)

# Logging Configuration
LOG_LEVEL=info

# CORS Configuration
ALLOWED_ORIGINS =http://localhost:8080

# --- Frontend Configuration ---
# Supabase Configuration (Used by both if backend needs it)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-key

# API Base URL (Frontend Only) - Points to the backend Next.js server
VITE_API_BASE_URL=http://localhost:4000
