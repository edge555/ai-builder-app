{
  "name": "ai-app-builder",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:shared\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:shared": "npm run dev --workspace=@ai-app-builder/shared",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:all": "npm run dev",
    "dev:backend": "npm run dev --workspace=@ai-app-builder/backend -- -p 4000",
    "build": "npm run build --workspace=@ai-app-builder/shared && npm run build --workspace=frontend && npm run build --workspace=@ai-app-builder/backend",
    "build:dev": "npm run build:dev --workspace=frontend",
    "preview": "npm run preview --workspace=frontend",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspace=frontend",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.3.3"
  }
}